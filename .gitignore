################################################################################
# PLAYWRIGHT & AUTOMATION TEST FRAMEWORK - GITIGNORE
################################################################################

################################################################################
# DEPENDENCIES & PACKAGES
################################################################################
node_modules/
package-lock.json
yarn.lock
.pnpm-lock.yaml
pnpm-lock.yaml

################################################################################
# ENVIRONMENT & SECRETS
################################################################################
# Environment variables - NEVER commit sensitive data
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
# Keep example file as reference
!.env.example

# Environment files for CI (specific configs)
.envUI
.envAPI

# Secrets and API keys
.secrets/
secrets.json
credentials.json

################################################################################
# TEST RESULTS & REPORTS
################################################################################
# Allure reporting
allure-results/
allure-report/
.allure/

# Playwright reports
playwright-report/
test-results/
test-results.json
html-results/

# Cucumber reports
reports/
cucumber-report.html
cucumber-report.json
junit-report.xml

# Video & screenshot artifacts
videos/
screenshots/
artifacts/

# Coverage reports
coverage/
.nyc_output/
*.lcov

